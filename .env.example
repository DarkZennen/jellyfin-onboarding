# Copy this file to .env and fill in your real values.
# .env is gitignored — your real values never get committed.
#
#   cp .env.example .env
#   nano .env

# Your Jellyfin server's public URL. Required.
JELLYFIN_SERVER_URL=https://jellyfin.yourdomain.com

# Your Wizarr instance's public URL. Only needed if you use Wizarr for
# invites — if you don't, leave this as the placeholder; the invite
# flow simply won't be used.
WIZARR_URL=https://invites.yourdomain.com

# What your server is called. Shown to end users on the welcome screen
# and "Open ___" buttons throughout the wizard.
SERVER_NAME=My Jellyfin Server

# The domain THIS wizard itself will be reachable at. Only used for the
# Traefik label in docker-compose.yml — if you're not using Traefik,
# you can ignore this or remove the Traefik labels entirely.
ONBOARDING_DOMAIN=watch.yourdomain.com
